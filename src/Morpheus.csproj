<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>morpheus</AssemblyName>
    <RootNamespace>Morpheus</RootNamespace>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RollForward>Major</RollForward>
    <PublishReadyToRun>false</PublishReadyToRun>
    <TieredCompilation>true</TieredCompilation>
    <ApplicationIcon></ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4" />
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\avatars\**\*" CopyToOutputDirectory="PreserveNewest" Link="avatars\%(RecursiveDir)%(Filename)%(Extension)" />
    <None Include="..\templates\**\*" CopyToOutputDirectory="PreserveNewest" Link="templates\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
